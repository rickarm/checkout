<!DOCTYPE html>
<html lang="en" data-theme="<%= userTheme %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
  <title><%= userName %>'s Journal — Login</title>
  <link rel="stylesheet" href="/css/doogie.css">
  <meta name="theme-color" content="#111">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;700&family=Nunito:wght@400;700&display=swap" rel="stylesheet">
  <script>
    (function () {
      var saved = localStorage.getItem('checkout-theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
    })();
  </script>
</head>
<body>
  <div class="dos-desktop">
    <div class="dos-container">
      <div class="scanlines"></div>
      <div class="screen-header">
        <span class="header-title"><%= userName.toUpperCase() %>'S JOURNAL</span>
      </div>
      <div class="screen-body">
        <div class="step-login">
          <p class="prompt-text amber">Password required for <%= userName %>.</p>

          <% if (error) { %>
            <div class="terminal-error">
              <span class="error">ERROR:</span> <%= error %>
            </div>
          <% } %>

          <form class="terminal-form" method="POST" action="/u/<%= user %>/login">
            <div class="terminal-input-wrapper">
              <span class="input-prompt amber">&gt; </span>
              <input
                type="password"
                name="password"
                class="terminal-input"
                autocomplete="current-password"
                autofocus
                required
              >
            </div>
            <div class="form-actions">
              <button type="submit" class="terminal-btn">[Enter] Unlock</button>
              <a href="/" class="terminal-btn dim">[Esc] Back</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
