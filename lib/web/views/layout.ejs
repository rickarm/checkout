<!DOCTYPE html>
<html lang="en" data-theme="<%= userTheme %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
  <title><%= userName %>'s Journal</title>
  <link rel="stylesheet" href="/css/doogie.css">
  <link rel="manifest" href="/manifest.json">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black">
  <meta name="theme-color" content="#0000AA">
  <!-- Both fonts preloaded; CSS picks the right one per theme -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;700&family=Nunito:wght@400;700&display=swap" rel="stylesheet">
  <!-- Apply saved theme preference before paint to avoid flash -->
  <script>
    (function () {
      var saved = localStorage.getItem('checkout-theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
    })();
  </script>
</head>
<body>
  <div class="dos-desktop">
    <div class="dos-container">
      <div class="scanlines"></div>
      <div class="screen-header">
        <span class="header-title"><%= userName.toUpperCase() %>'S JOURNAL</span>
        <nav class="header-nav">
          <a href="/u/<%= user %>"
             hx-get="/u/<%= user %>/step/breathing"
             hx-target="#screen-content"
             hx-push-url="/u/<%= user %>"
             class="nav-link">New Entry</a>
          <span class="nav-sep">|</span>
          <a href="/u/<%= user %>/history"
             hx-get="/u/<%= user %>/history"
             hx-target="#screen-content"
             hx-push-url="/u/<%= user %>/history"
             class="nav-link">History</a>
          <% if (allUsers && allUsers.length > 1) { %>
            <span class="nav-sep">|</span>
            <a href="/" class="nav-link">Switch</a>
          <% } %>
          <span class="nav-sep">|</span>
          <button class="theme-toggle" onclick="toggleTheme()" title="Switch theme">◈</button>
        </nav>
      </div>
      <div class="screen-body" id="screen-content">
        <% if (partial === 'breathing') { %>
          <%- include('breathing') %>
        <% } else if (partial === 'history') { %>
          <%- include('history', { grouped, total }) %>
        <% } else if (partial === 'entry') { %>
          <%- include('entry', { content, filename, error, prevUrl, nextUrl }) %>
        <% } %>
      </div>
    </div>
  </div>

  <script src="https://unpkg.com/htmx.org@1.9.12"></script>
  <script src="https://unpkg.com/alpinejs@3.14.3/dist/cdn.min.js" defer></script>
  <script src="/js/terminal.js"></script>

  <% if (typeof registerSW === 'undefined' || registerSW !== false) { %>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    }
  </script>
  <% } %>
</body>
</html>
