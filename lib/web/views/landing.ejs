<!DOCTYPE html>
<html lang="en" data-theme="doogie">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
  <title>Checkout Journal</title>
  <link rel="stylesheet" href="/css/doogie.css">
  <link rel="manifest" href="/manifest.json">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black">
  <meta name="theme-color" content="#111">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;700&family=Nunito:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="dos-desktop">
    <div class="dos-container">
      <div class="scanlines"></div>
      <div class="screen-header">
        <span class="header-title">CHECKOUT JOURNAL</span>
      </div>
      <div class="screen-body">
        <div class="page-landing">
          <p class="landing-title amber">Who's journaling tonight?</p>
          <div class="landing-users">
            <% for (const u of users) { %>
              <a href="/u/<%= u.id %>" class="user-btn"><%= u.displayName %></a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
