<%
  // prevUrl = older entry, nextUrl = newer entry (passed from server)
  const safePrev = typeof prevUrl !== 'undefined' ? prevUrl : null;
  const safeNext = typeof nextUrl !== 'undefined' ? nextUrl : null;
%>
<div class="page-entry"
     x-data="entryView('<%= safePrev || '' %>', '<%= safeNext || '' %>')"
     x-init="start()"
     @touchstart.passive="handleTouchStart($event)"
     @touchend.passive="handleTouchEnd($event)">

  <div class="entry-header">
    <a
      href="/u/<%= user %>/history"
      hx-get="/u/<%= user %>/history"
      hx-target="#screen-content"
      hx-swap="innerHTML"
      class="terminal-btn-inline"
    >&lt; Back</a>

    <div class="entry-nav">
      <% if (safePrev) { %>
        <a href="<%= safePrev %>"
           hx-get="<%= safePrev %>"
           hx-target="#screen-content"
           hx-swap="innerHTML"
           class="entry-nav-btn"
           title="Older entry">← Older</a>
      <% } else { %>
        <span class="entry-nav-btn disabled">← Older</span>
      <% } %>

      <% if (safeNext) { %>
        <a href="<%= safeNext %>"
           hx-get="<%= safeNext %>"
           hx-target="#screen-content"
           hx-swap="innerHTML"
           class="entry-nav-btn"
           title="Newer entry">Newer →</a>
      <% } else { %>
        <span class="entry-nav-btn disabled">Newer →</span>
      <% } %>
    </div>
  </div>

  <div class="entry-separator">
    <span class="dim">──────────────────────────────────────────</span>
  </div>

  <% if (error) { %>
    <div class="terminal-error">
      <span class="error">ERROR:</span> <%= error %>
    </div>
  <% } else if (content) { %>
    <div class="entry-content" x-show="visible" x-cloak>
      <% const lines = content.split('\n'); %>
      <% for (const line of lines) { %>
        <% if (line.startsWith('## ')) { %>
          <p class="entry-question amber"><%= line.replace('## ', '') %></p>
        <% } else if (line.startsWith('---')) { %>
          <p class="dim">──────────────────────────────────────────</p>
        <% } else if (line.startsWith('**Metadata**')) { %>
          <p class="dim"><%= line.replace(/\*\*/g, '') %></p>
        <% } else if (line.startsWith('- ')) { %>
          <p class="dim"><%= line %></p>
        <% } else if (line.trim()) { %>
          <p class="entry-answer"><%= line %></p>
        <% } %>
      <% } %>
    </div>
  <% } %>
</div>
